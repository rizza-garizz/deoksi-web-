#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_DIR="$ROOT_DIR/.local/node-v20.19.0-darwin-x64/bin"
NPM_BIN="$NODE_DIR/npm"
if [ ! -x "$NPM_BIN" ]; then
  echo "Local npm not found at $NPM_BIN"
  echo "Run setup first to install local Node.js into .local/"
  exit 1
fi
export PATH="$NODE_DIR:$PATH"
exec "$NPM_BIN" "$@"
