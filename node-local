#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_BIN="$ROOT_DIR/.local/node-v20.19.0-darwin-x64/bin/node"
if [ ! -x "$NODE_BIN" ]; then
  echo "Local Node.js not found at $NODE_BIN"
  echo "Run setup first to install local Node.js into .local/"
  exit 1
fi
exec "$NODE_BIN" "$@"
