# =============================================
# Deoksi Beauty Clinic - Environment Variables
# =============================================
# Copy file ini menjadi .env dan isi value-nya

# Neon.tech PostgreSQL Connection String
# Dapatkan dari: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://username:password@ep-xxxxx.region.neon.tech/dbname?sslmode=require

# JWT Secret Key (ganti dengan string random yang panjang)
JWT_SECRET=your-super-secret-jwt-key-here-2026

# Password Salt untuk hashing (ganti dengan string random)
PASSWORD_SALT=deoksi2026

# Cloudinary (untuk media upload)
# Dapatkan dari: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=deoksi_unsigned
