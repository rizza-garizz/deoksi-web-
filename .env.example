# =============================================
# Deoksi Beauty Clinic - Environment Variables
# =============================================
# Copy file ini menjadi .env lalu isi semua value REQUIRED.
# File ini sudah disusun untuk deploy Node app di Hostinger + Neon.

# REQUIRED - Neon PostgreSQL
# Ambil dari Neon Console → Project → Connection Details.
DATABASE_URL=postgresql://username:password@ep-xxxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require

# REQUIRED - Auth admin
# Gunakan string acak panjang, jangan pakai value contoh di production.
JWT_SECRET=replace-with-a-long-random-secret
PASSWORD_SALT=replace-with-a-second-random-secret

# OPTIONAL / CONDITIONAL - Cloudinary
# Dipakai untuk validasi video Cloudinary dan upload image dashboard.
# Jika dua value utama diisi, /api/upload akan mengirim file ke Cloudinary.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
CLOUDINARY_UPLOAD_FOLDER=deoksi/uploads
