# =============================================
# Deoksi Beauty Clinic - Docker Compose Env
# =============================================
# Copy file ini menjadi .env.docker atau export value-nya
# sebelum menjalankan `docker compose up --build`.

# =============================================
# App
# =============================================
JWT_SECRET=replace-with-a-long-random-secret
PASSWORD_SALT=replace-with-a-second-random-secret

# OPTIONAL - jika belum diisi, app masih bisa jalan pada mode lokal default
DATABASE_URL=postgresql://deoksi:deoksi123@db:5432/deoksi

# =============================================
# PostgreSQL Container
# =============================================
POSTGRES_DB=deoksi
POSTGRES_USER=deoksi
POSTGRES_PASSWORD=deoksi123

# =============================================
# Cloudinary
# =============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-unsigned-upload-preset
CLOUDINARY_UPLOAD_FOLDER=deoksi/uploads

# =============================================
# Redis
# =============================================
REDIS_URL=redis://redis:6379

# =============================================
# Docker DB Bootstrap
# =============================================
# Gunakan DATABASE_URL ini saat menjalankan:
# npm run docker:init-db
